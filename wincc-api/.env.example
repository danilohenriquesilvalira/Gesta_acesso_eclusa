# ── Base de Dados ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://wincc:senha@localhost:5432/wincc_acesso

# ── Autenticação ──────────────────────────────────────────────────────────────
JWT_SECRET=muda_para_string_aleatoria_longa_em_producao
# Para gerar: openssl rand -hex 32

# ── RDP ───────────────────────────────────────────────────────────────────────
RDP_USER=Administrator
RDP_PASSWORD=senha_rdp

# ── IPs dos clientes RDP (overrides do hardcoded em config.rs) ────────────────
CLIENT1_IP=172.29.164.49
CLIENT2_IP=172.29.164.51

# ── IPs dos PLCs (Siemens S7, porta 102) ──────────────────────────────────────
PLC_PN_IP=172.29.160.33
PLC_PN_PORT=102
PLC_RG_IP=172.29.162.33
PLC_RG_PORT=102
# CL, CM, VR — a confirmar com cliente
# PLC_CL_IP=10.10.1.10
# PLC_CM_IP=10.10.2.10
# PLC_VR_IP=10.10.5.10

# ── Servidor ──────────────────────────────────────────────────────────────────
API_PORT=8080

# ── Modo Simulação (dev/bancada sem rede real) ────────────────────────────────
# SIM_MODE=true  → RDP sempre acessível+livre, PLCs sempre online
# Permite correr e testar tudo sem VMs WinCC nem PLCs fisicamente ligados
SIM_MODE=false

# ── Bootstrap de desenvolvimento (APENAS DEV — remover em produção) ───────────
# Se não existir NENHUM admin na BD, cria utilizador admin com esta senha.
# Depois do primeiro arranque podes remover esta linha.
# Utilizador criado: username=admin, role=admin
# BOOTSTRAP_ADMIN_PASSWORD=admin123
