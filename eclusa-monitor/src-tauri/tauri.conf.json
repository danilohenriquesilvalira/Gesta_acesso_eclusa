{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eclusa-monitor",
  "version": "0.1.0",
  "identifier": "com.edp.eclusa-monitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Controlo de Acesso — Eclusas WinCC",
        "width": 2560,
        "height": 1440,
        "x": 628,
        "y": -1440,
        "fullscreen": true,
        "decorations": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
